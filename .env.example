# ===========================================================
# ACY Quotation & Accounting Document System - Environment Variables
# Copy this file to .env and adjust values before running.
# ===========================================================

# --- Database (PostgreSQL) ---
POSTGRES_USER=acy_admin
POSTGRES_PASSWORD=ChangeMe_StrongPassword!
POSTGRES_DB=acy_quotation
# NOTE: default changed from 5432 to 5433 to avoid clashing with a
# PostgreSQL instance already installed natively on many dev/staging
# machines. Change further if 5433 is also taken.
POSTGRES_PORT=5433
# Used by the app container (host name = docker-compose service name "db")
DATABASE_URL=postgresql://acy_admin:ChangeMe_StrongPassword!@db:5432/acy_quotation?schema=public

# --- App / Web ---
# Port exposed on the HOST machine (via the nginx reverse proxy).
# NOTE: default changed from 8080 to 8090 - 8080 was already bound by
# another service on the reference dev machine. Change again if needed.
HOST_PORT=8090
NEXTAUTH_URL=http://localhost:8090
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=please_generate_a_random_32byte_base64_secret

# --- Session ---
SESSION_MAX_AGE_MINUTES=480

# --- File storage (local disk, mounted as a Docker volume) ---
STORAGE_PATH=/app/storage
MAX_UPLOAD_SIZE_MB=15

# --- Business defaults (can be overridden later from Admin > Company Settings) ---
DEFAULT_VAT_RATE=7
DEFAULT_CURRENCY=THB
DEFAULT_MIN_GP_PERCENT=15

# --- Backup ---
BACKUP_PATH=/app/storage/backups
BACKUP_RETENTION_DAYS=30
# Cron schedule for automatic daily backup (container: backup service)
BACKUP_CRON=0 2 * * *

# --- Initial Admin account (created by prisma/seed.ts on first run) ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=P@ssw0rd
SEED_ADMIN_EMAIL=admin@acy.local
